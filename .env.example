# ── Backend Configuration ───────────────────────────────────
# Flask debug mode (NEVER set to true in production)
FLASK_DEBUG=false

# Host binding (127.0.0.1 = localhost only, 0.0.0.0 = all interfaces)
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# API Key — leave empty to disable auth (dev mode)
# Set a strong random string in production: openssl rand -hex 32
PENTASCOPE_API_KEY=

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend Configuration ──────────────────────────────────
# (put in frontend/.env)
# REACT_APP_API_URL=http://localhost:5000
